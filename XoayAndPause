#include <iostream>
#include <conio.h>
#include <windows.h>
#include <time.h>

using namespace std;

#define H 20
#define W 15

// ======================================================
// 1. LỚP TRỪU TƯỢNG PIECE (Áp dụng Đa hình)
// ======================================================
// THAY ĐỔI: Chuyển đổi từ Class bán-đa-hình ở code dưới thành Lớp cơ sở trừu tượng thực sự.
// THAY ĐỔI: Đưa thuộc tính vị trí x, y từ biến toàn cục (global) vào bên trong thuộc tính của Class.
// THAY ĐỔI: Chuyển đổi phạm vi truy cập thuộc tính 'shape' thành public để đơn giản hóa việc truy xuất,
//           thay vì phải trả về con trỏ mảng phức tạp char (*getShape())[4] như phiên bản cũ.
class Piece {
public:
    char shape[4][4];
    int x, y; // THAY ĐỔI: Mỗi đối tượng block bây giờ tự quản lý tọa độ của chính nó trên board.

    Piece() {
        x = 5; y = 0; // Khởi tạo vị trí mặc định tại đỉnh board khi một block được sinh ra.
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++) shape[i][j] = ' ';
    }

    // Hàm ảo thuần túy: Ép buộc các lớp con phải tự định nghĩa cách xoay
    virtual void rotate() = 0;

    // Logic kiểm tra va chạm dùng chung
    // THAY ĐỔI: Thay thế cho hàm canMove() và canRotate() riêng lẻ ở code dưới.
    // Hàm này cho phép truyền một mảng hình dạng bất kỳ (testShape) vào để kiểm tra va chạm tại vị trí (nx, ny).
    // Giúp loại bỏ hoàn toàn việc phải clone/tạo vùng nhớ nháp bằng dynamic_cast rất tốn tài nguyên khi xoay block.
    bool canFit(int nx, int ny, char board[H][W], char testShape[4][4]) {
        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                if (testShape[i][j] != ' ') {
                    int tx = nx + j;
                    int ty = ny + i;
                    // Kiểm tra va chạm biên trái, biên phải và đáy board
                    if (tx < 1 || tx >= W - 1 || ty >= H - 1) return false;
                    // Kiểm tra va chạm với các khối gạch cố định đã có sẵn trên board
                    if (ty >= 0 && board[ty][tx] != ' ') return false;
                }
            }
        }
        return true;
    }
    virtual ~Piece() {}
};

// ======================================================
// 2. CÁC LỚP CON (Định nghĩa cách xoay riêng biệt)
// ======================================================
// THAY ĐỔI: Thay vì dùng chung một class TetrisPiece nhận mảng dữ liệu thô 'blocksData' từ bên ngoài,
//           mỗi loại block bây giờ là một Class riêng biệt kế thừa từ Piece, hiện thực hóa tính Đa hình (Polymorphism).

class PieceI : public Piece {
public:
    PieceI() {
        char s[4][4] = {{' ','I',' ',' '},{' ','I',' ',' '},{' ','I',' ',' '},{' ','I',' ',' '}};
        memcpy(shape, s, 16);
    }
    // Định nghĩa hành vi xoay ma trận 90 độ riêng cho khối I
    void rotate() override {
        char temp[4][4];
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++) temp[j][3 - i] = shape[i][j];
        memcpy(shape, temp, 16);
    }
};

class PieceO : public Piece {
public:
    PieceO() {
        char s[4][4] = {{' ',' ',' ',' '},{' ','O','O',' '},{' ','O','O',' '},{' ',' ',' ',' '}};
        memcpy(shape, s, 16);
    }
    // THAY ĐỔI TỐI ƯU: Khối O bản chất xoay 90 độ không đổi hình dạng.
    // Lớp con này override hàm rotate() rỗng để không phải tính toán ma trận vô ích, tối ưu hiệu năng.
    void rotate() override {
        // Khối O xoay không đổi hình dạng -> Không cần làm gì
    }
};

class PieceT : public Piece {
public:
    PieceT() {
        char s[4][4] = {{' ',' ',' ',' '},{' ','T',' ',' '},{'T','T','T',' '},{' ',' ',' ',' '}};
        memcpy(shape, s, 16);
    }
    // Định nghĩa hành vi xoay ma trận 90 độ riêng cho khối T
    void rotate() override {
        char temp[4][4];
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++) temp[j][3 - i] = shape[i][j];
        memcpy(shape, temp, 16);
    }
};

// ======================================================
// 3. LỚP QUẢN LÝ GAME (TetrisGame)
// ======================================================
// THAY ĐỔI LỚN NHẤT: Gom toàn bộ các biến toàn cục (board, score, speed, paused)
// và các hàm xử lý rời rạc ở code dưới vào trong một Class quản lý duy nhất theo đúng nguyên lý Đóng gói (Encapsulation).
class TetrisGame {
private:
    char board[H][W];
    Piece* current; // Áp dụng Đa hình: Con trỏ lớp cha quản lý các đối tượng lớp con (PieceI, PieceO, PieceT).
    int score;
    int speed;
    bool paused;

    // Phương thức ẩn di chuyển con trỏ điều khiển màn hình Console
    void gotoxy(int x, int y) {
        COORD c = {(SHORT)x, (SHORT)y};
        SetConsoleCursorPosition(GetStdHandle(STD_OUTPUT_HANDLE), c);
    }

public:
    // Constructor khởi tạo trạng thái Game, thay thế cho hàm initBoard() rời rạc ở phiên bản cũ
    TetrisGame() : score(0), speed(200), paused(false) {
        for (int i = 0; i < H; i++) {
            for (int j = 0; j < W; j++)
                board[i][j] = (i == H - 1 || j == 0 || j == W - 1) ? '#' : ' ';
        }
        current = spawnPiece();
    }

    // Phương thức sinh ngẫu nhiên một đối tượng block con thông qua con trỏ lớp cha Piece
    Piece* spawnPiece() {
        int r = rand() % 3; // Hiện tại code trên đang hỗ trợ 3 loại block (I, O, T)
        if (r == 0) return new PieceI();
        if (r == 1) return new PieceO();
        return new PieceT();
    }

    // Phương thức vẽ giao diện màn hình game ra console
    void draw() {
        gotoxy(0, 0);
        for (int i = 0; i < H; i++) {
            for (int j = 0; j < W; j++) {
                if (board[i][j] == ' ') cout << "  ";
                else cout << "[]";
            }
            cout << endl;
        }
        cout << "\nSCORE: " << score << " | SPEED: " << speed;
        cout << "\nSTATUS: " << (paused ? "PAUSED (P to resume)" : "PLAYING            ") << endl;
        cout << "[W] Xoay | [A,D] Di chuyen | [S] Roi nhanh | [P] Pause | [Q] Quit";
    }

    // THAY ĐỔI: Gộp hai hàm boardDelBlock() và block2Board() riêng lẻ của code dưới thành một hàm duy nhất.
    // Truyền tham số true để ghi đè khối gạch lên board (Draw), truyền false để xóa khối gạch khỏi board (Clear).
    void syncBoard(bool isAdding) {
        for (int i = 0; i < 4; i++)
            for (int j = 0; j < 4; j++)
                if (current->shape[i][j] != ' ' && current->y + i >= 0)
                    board[current->y + i][current->x + j] = isAdding ? current->shape[i][j] : ' ';
    }

    // Phương thức quét tìm và loại bỏ các hàng đã xếp đầy gạch
    // THAY ĐỔI: Tích hợp trực tiếp logic cộng điểm và tự động tăng tốc độ thông qua hàm max() tối ưu.
    void clearLines() {
        for (int i = H - 2; i >= 0; i--) {
            bool full = true;
            for (int j = 1; j < W - 1; j++) if (board[i][j] == ' ') full = false;
            if (full) {
                score += 100;
                speed = max(50, speed - 10); // Tăng tốc độ bằng cách giảm thời gian Sleep nhưng giới hạn tối thiểu là 50ms
                // Dịch chuyển các hàng phía trên xuống thế chỗ hàng vừa bị xóa
                for (int k = i; k > 0; k--)
                    for (int j = 1; j < W - 1; j++) board[k][j] = board[k - 1][j];
                i++; // Kiểm tra lại hàng hiện tại sau khi dịch chuyển dữ liệu xuống
            }
        }
    }

    // Phương thức chạy vòng lặp Game chính (Game Loop)
    // THAY ĐỔI: Đưa toàn bộ cấu trúc xử lý trong hàm main() cũ của code dưới vào đây, giúp code main gọn sạch.
    void run() {
        while (true) {
            // 1. Kiểm tra và bắt sự kiện phím nhấn từ người dùng
            if (_kbhit()) {
                char c = tolower(_getch());
                if (c == 'q') break; // Thoát game
                if (c == 'p') { paused = !paused; continue; } // Tạm dừng / Chơi tiếp

                if (!paused) {
                    syncBoard(false); // Xóa vị trí cũ của block trước khi dịch chuyển

                    // Kiểm tra va chạm tương ứng với các phím A (Trái), D (Phải), S (Rơi nhanh)
                    if (c == 'a' && current->canFit(current->x - 1, current->y, board, current->shape)) current->x--;
                    if (c == 'd' && current->canFit(current->x + 1, current->y, board, current->shape)) current->x++;
                    if (c == 's' && current->canFit(current->x, current->y + 1, board, current->shape)) current->y++;

                    // Xử lý xoay khối gạch khi bấm phím W
                    if (c == 'w') {
                        char temp[4][4];
                        // Tạo ma trận xoay tạm thời để check va chạm trước
                        for (int i = 0; i < 4; i++) for (int j = 0; j < 4; j++) temp[j][3 - i] = current->shape[i][j];
                        // THAY ĐỔI: Nếu xoay được thì gọi hàm xoay ảo thực tế, không cần cấp phát/giải phóng bộ nhớ nháp.
                        if (current->canFit(current->x, current->y, board, temp)) current->rotate();
                    }
                    syncBoard(true); // Cập nhật vẽ block tại vị trí mới lên board
                }
            }

            // 2. Xử lý logic tự động rơi theo thời gian thực (khi không bị Pause)
            if (!paused) {
                syncBoard(false); // Tạm xóa block ở vị trí hiện tại để tính toán bước rơi tiếp theo
                // Nếu khối gạch có thể rơi tiếp xuống dưới
                if (current->canFit(current->x, current->y + 1, board, current->shape)) {
                    current->y++;
                    syncBoard(true); // Ghi nhận vị trí rơi mới
                } else {
                    // Nếu khối gạch chạm đáy hoặc chạm vật cản cố định
                    syncBoard(true); // Khóa cứng vị trí block hiện tại vào board
                    clearLines();    // Kiểm tra hàng đầy và xóa
                    delete current;  // Giải phóng vùng nhớ của block vừa rơi xong

                    current = spawnPiece(); // Tạo block mới ngẫu nhiên tiếp theo

                    // THAY ĐỔI LOGIC SỬA LỖI: Kiểm tra Game Over ngay khi block mới vừa xuất hiện.
                    // Nếu vị trí xuất phát đã bị nghẽn (không thể Fit), Game kết thúc ngay, chính xác hơn phiên bản cũ.
                    if (!current->canFit(current->x, current->y, board, current->shape)) {
                        system("cls");
                        cout << "GAME OVER! SCORE: " << score << endl;
                        break;
                    }
                }
            }

            // 3. Render khung hình game và thiết lập nhịp độ game
            draw();
            Sleep(speed);
        }
    }

    // Destructor: Giải phóng vùng nhớ con trỏ đang quản lý tránh rò rỉ bộ nhớ (Memory Leak)
    ~TetrisGame() { delete current; }
};

// ======================================================
// 4. HÀM KHỞI CHẠY CHÍNH (Main Function)
// ======================================================
// THAY ĐỔI: Hàm main cực kỳ ngắn gọn, nhiệm vụ duy nhất là khởi tạo đối tượng Game và kích hoạt vòng lặp chạy.
int main() {
    srand((unsigned int)time(0)); // Thiết lập seed ngẫu nhiên dựa trên thời gian hệ thống
    TetrisGame game;              // Tạo instance của class quản lý game
    game.run();                   // Kích hoạt vòng lặp game loop chính
    return 0;
}
