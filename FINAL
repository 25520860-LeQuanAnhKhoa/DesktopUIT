// ==========================================
// GLOBAL VARIABLES
// ==========================================

char board[H][W];

Piece* currentPiece = nullptr;

int x = 5;
int y = 0;

int score = 0;

int speed = 200;

int gameMode = 1;

const int MIN_SPEED = 50;

// ==========================================
// SET COLOR
// ==========================================

void setColor(int color) {
    SetConsoleTextAttribute(GetStdHandle(STD_OUTPUT_HANDLE), color);
}

// ==========================================
// SOUND
// ==========================================

void soundMove() {
    Beep(600, 50);
}

void soundRotate() {
    Beep(800, 80);
}

void soundDrop() {
    Beep(500, 40);
}

void soundClear() {
    Beep(1000, 150);
}

void soundGameOver() {
    Beep(400, 300);
    Beep(300, 300);
    Beep(200, 500);
}

// ==========================================
// GOTOXY
// ==========================================

void gotoxy(int x, int y) {

    COORD c = { (SHORT)x, (SHORT)y };

    SetConsoleCursorPosition(
        GetStdHandle(STD_OUTPUT_HANDLE),
        c
    );
}

// ==========================================
// INIT BOARD
// ==========================================

void initBoard() {

    for (int i = 0; i < H; i++) {

        for (int j = 0; j < W; j++) {

            if (i == H - 1 || j == 0 || j == W - 1)
                board[i][j] = '#';

            else
                board[i][j] = ' ';
        }
    }
}

// ==========================================
// SPAWN NEW PIECE
// ==========================================

void spawnNewPiece() {

    int b = rand() % 7;

    if (currentPiece != nullptr)
        delete currentPiece;

    currentPiece = new TetrisPiece(blocksData[b]);

    x = 5;
    y = 0;
}

// ==========================================
// GET SHAPE
// ==========================================

char (*shape())[4] {

    return currentPiece->getShape();
}

// ==========================================
// DRAW
// ==========================================

void draw() {

    static char buffer[H][W];
    static string output;

    output.clear();

    // Copy board vào buffer
    for (int i = 0; i < H; i++) {
        for (int j = 0; j < W; j++) {
            buffer[i][j] = board[i][j];
        }
    }

    // Render buffer thành string 1 lần
    for (int i = 0; i < H; i++) {
        for (int j = 0; j < W; j++) {
            if (buffer[i][j] == ' ')
                output += "  ";
            else
                output += "[]";
        }
        output += '\n';
    }

    output += "\n========== TETRIS ==========\n";
    output += "SCORE : " + to_string(score) + "\n";
    output += "SPEED : " + to_string(speed) + "\n";
    output += "MODE  : ";
    output += (gameMode == 1 ? "EASY\n" : "HARD\n");

    output += "\nA : LEFT\n";
    output += "D : RIGHT\n";
    output += "S : DOWN\n";
    output += "W : ROTATE\n";
    output += "SPACE : HARD DROP\n";
    output += "P : PAUSE\n";
    output += "Q : QUIT\n";

    gotoxy(0, 0);
    cout << output;
}
// ==========================================
// DELETE TEMP BLOCK
// ==========================================

void boardDelBlock() {

    auto s = shape();

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            if (s[i][j] != ' ') {

                if (y + i >= 0 && y + i < H &&
                    x + j >= 0 && x + j < W) {

                    board[y + i][x + j] = ' ';
                }
            }
        }
    }
}

// ==========================================
// DRAW BLOCK
// ==========================================

void block2Board() {

    auto s = shape();

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            if (s[i][j] != ' ') {

                board[y + i][x + j] = s[i][j];
            }
        }
    }
}

// ==========================================
// CAN MOVE
// ==========================================

bool canMove(int dx, int dy) {

    auto s = shape();

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            if (s[i][j] != ' ') {

                int tx = x + j + dx;
                int ty = y + i + dy;

                if (tx < 1 || tx >= W - 1 ||
                    ty >= H - 1)
                    return false;

                if (board[ty][tx] != ' ')
                    return false;
            }
        }
    }

    return true;
}

// ==========================================
// CAN ROTATE
// ==========================================

bool canRotate() {

    TetrisPiece temp(
        *dynamic_cast<TetrisPiece*>(currentPiece)
    );

    temp.rotate();

    auto s = temp.getShape();

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            if (s[i][j] != ' ') {

                int tx = x + j;
                int ty = y + i;

                if (tx < 1 || tx >= W - 1 ||
                    ty >= H - 1)
                    return false;

                if (board[ty][tx] != ' ')
                    return false;
            }
        }
    }

    return true;
}

// ==========================================
// ROTATE BLOCK
// ==========================================

void rotateBlock() {

    currentPiece->rotate();
}

// ==========================================
// REMOVE FULL LINES
// ==========================================

int removeLines() {

    int linesCleared = 0;

    for (int i = H - 2; i >= 0; i--) {

        bool full = true;

        for (int j = 1; j < W - 1; j++) {

            if (board[i][j] == ' ') {

                full = false;
                break;
            }
        }

        if (full) {

            linesCleared++;

            for (int k = i; k > 0; k--) {

                for (int j = 1; j < W - 1; j++) {

                    board[k][j] = board[k - 1][j];
                }
            }

            for (int j = 1; j < W - 1; j++) {

                board[0][j] = ' ';
            }

            soundClear();

            i++;
        }
    }

    return linesCleared;
}

// ==========================================
// INCREASE SPEED
// ==========================================

void increaseSpeed(int linesCleared) {

    if (gameMode == 1)
        speed -= linesCleared * 5;

    else
        speed -= linesCleared * 20;

    if (speed < MIN_SPEED)
        speed = MIN_SPEED;
}

// ==========================================
// GAME OVER
// ==========================================

bool gameOver() {

    for (int j = 1; j < W - 1; j++) {

        if (board[0][j] != ' ')
            return true;
    }

    return false;
}

// ==========================================
// HIDE CURSOR
// ==========================================

void hideCursor() {
    HANDLE consoleHandle = GetStdHandle(STD_OUTPUT_HANDLE);
    CONSOLE_CURSOR_INFO info;
    info.dwSize = 100;
    info.bVisible = FALSE;
    SetConsoleCursorInfo(consoleHandle, &info);
}

// ==========================================
// MAIN
// ==========================================

int main() {

    srand((unsigned int)time(0));

    gotoxy(0, 0);
    hideCursor();
    cout << "====== TETRIS ======" << endl;
    cout << "1. EASY MODE" << endl;
    cout << "2. HARD MODE" << endl;
    cout << "Choose mode: ";

    cin >> gameMode;

    if (gameMode == 1)
        speed = 300;

    else
        speed = 120;

    initBoard();

    spawnNewPiece();

    bool paused = false;

    while (true) {

        boardDelBlock();

        // ======================
        // INPUT
        // ======================

        if (_kbhit()) {

            char c = _getch();
            c = tolower(c); // FIX: Chuyển toàn bộ phím bấm về chữ thường để tránh lỗi do CapsLock

            if (c == 'p') {

                paused = !paused;
            }

            if (paused) {

                block2Board();
                draw();
                continue;
            }

            if (c == 'a') {

                if (canMove(-1, 0)) {

                    x--;
                    soundMove();
                }
            }

            else if (c == 'd') {

                if (canMove(1, 0)) {

                    x++;
                    soundMove();
                }
            }

            else if (c == 's') {

                if (canMove(0, 1)) {

                    y++;
                    soundDrop();
                }
            }

            else if (c == 'w') {

                if (canRotate()) {

                    rotateBlock();
                    soundRotate();
                }
            }

            // HARD DROP
            else if (c == ' ') {

                while (canMove(0, 1)) {

                    y++;
                }

                soundDrop();
            }

            else if (c == 'q') {

                break;
            }
        }

        // ======================
        // GAME UPDATE
        // ======================

        if (!paused) {

            if (canMove(0, 1)) {

                y++;
            }

            else {

                block2Board();

                int lines = removeLines();

                if (gameMode == 1)
                    score += lines * 100;

                else
                    score += lines * 200;

                increaseSpeed(lines);

                spawnNewPiece();

                // spawn overlap
                if (!canMove(0, 0)) {

                    system("cls");

                    cout << endl;
                    cout << "========= GAME OVER ========="
                        << endl;

                    cout << "FINAL SCORE : "
                        << score << endl;

                    cout << "============================="
                        << endl;

                    soundGameOver();

                    break;
                }
            }
        }

        block2Board();

        draw();

        Sleep(speed);
    }

    delete currentPiece;

    return 0;
}
