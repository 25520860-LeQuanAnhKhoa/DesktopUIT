// ==========================================
// ABSTRACT CLASS
// ==========================================

class Piece {

protected:
    char shape[4][4];

public:

    virtual void rotate() = 0;

    virtual char (*getShape())[4] = 0;

    virtual ~Piece() {}
};

// ==========================================
// TETRIS PIECE
// ==========================================

class TetrisPiece : public Piece {

public:

    TetrisPiece(char init[4][4]) {

        for (int i = 0; i < 4; i++) {

            for (int j = 0; j < 4; j++) {

                shape[i][j] = init[i][j];
            }
        }
    }

    char (*getShape())[4] override {

        return shape;
    }

    void rotate() override {

        char temp[4][4];

        for (int i = 0; i < 4; i++) {

            for (int j = 0; j < 4; j++) {

                temp[j][3 - i] = shape[i][j];
            }
        }

        for (int i = 0; i < 4; i++) {

            for (int j = 0; j < 4; j++) {

                shape[i][j] = temp[i][j];
            }
        }
    }
};

