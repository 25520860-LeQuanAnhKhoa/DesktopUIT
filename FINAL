#define W 15

char board[H][W] = {};

char blocks[][4][4] = {

    {
        {' ','I',' ',' '},
        {' ','I',' ',' '},
        {' ','I',' ',' '},
        {' ','I',' ',' '}
    },

    {
        {' ',' ',' ',' '},
        {' ','O','O',' '},
        {' ','O','O',' '},
        {' ',' ',' ',' '}
    },

    {
        {' ',' ',' ',' '},
        {' ','T',' ',' '},
        {'T','T','T',' '},
        {' ',' ',' ',' '}
    },

    {
        {' ',' ',' ',' '},
        {' ','S','S',' '},
        {'S','S',' ',' '},
        {' ',' ',' ',' '}
    },

    {
        {' ',' ',' ',' '},
        {'Z','Z',' ',' '},
        {' ','Z','Z',' '},
        {' ',' ',' ',' '}
    },

    {
        {' ',' ',' ',' '},
        {'J',' ',' ',' '},
        {'J','J','J',' '},
        {' ',' ',' ',' '}
    },

    {
        {' ',' ',' ',' '},
        {' ',' ','L',' '},
        {'L','L','L',' '},
        {' ',' ',' ',' '}
    }
};

int x = 5;
int y = 0;
int b;

int score = 0;

int speed = 200;
int gameMode=1;
const int MIN_SPEED = 50;
const int SPEED_STEP = 10;

void soundMove() {
    Beep(600, 50);     // di chuyển
}

void soundRotate() {
    Beep(800, 80);     // xoay
}

void soundDrop() {
    Beep(500, 40);     // rơi
}

void soundClear() {
    Beep(1000, 150);   // ăn dòng
}

void soundGameOver() {
    Beep(400, 300);
    Beep(300, 300);
    Beep(200, 500);
}

void gotoxy(int x, int y) {

    COORD c = { (SHORT)x, (SHORT)y };

    SetConsoleCursorPosition(
        GetStdHandle(STD_OUTPUT_HANDLE),
        c
    );
}

void initBoard() {

    for (int i = 0; i < H; i++) {

        for (int j = 0; j < W; j++) {

            if (i == H - 1 || j == 0 || j == W - 1)
                board[i][j] = '#';

            else
                board[i][j] = ' ';
        }
    }
}

void draw() {

    gotoxy(0, 0);

    for (int i = 0; i < H; i++) {

        for (int j = 0; j < W; j++) {

            if (board[i][j] == '#') {

                cout << "[]";
            }

            else if (board[i][j] == ' ') {

                cout << "  ";
            }

            else {

                cout << "[]";
            }
        }

        cout << endl;
    }

    cout << endl;
    cout << "========== TETRIS ==========" << endl;
    cout << "SCORE : " << score << endl;
    cout << "SPEED : " << speed << endl;
    cout << "MODE  : " << (gameMode == 1 ? "EASY" : "HARD") << endl;
    cout << endl;
    cout << "A : LEFT" << endl;
    cout << "D : RIGHT" << endl;
    cout << "S : DOWN" << endl;
    cout << "W : ROTATE" << endl;
    cout << "Q : QUIT" << endl;
}

void boardDelBlock() {

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            if (blocks[b][i][j] != ' ') {

                if (y + i >= 0 && y + i < H &&
                    x + j >= 0 && x + j < W) {

                    board[y + i][x + j] = ' ';
                }
            }
        }
    }
}

void block2Board() {

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            if (blocks[b][i][j] != ' ') {

                board[y + i][x + j] = blocks[b][i][j];
            }
        }
    }
}

bool canMove(int dx, int dy) {

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            if (blocks[b][i][j] != ' ') {

                int tx = x + j + dx;
                int ty = y + i + dy;

                if (tx < 1 || tx >= W - 1 || ty >= H - 1)
                    return false;

                if (board[ty][tx] != ' ')
                    return false;
            }
        }
    }

    return true;
}

bool canRotate() {

    char temp[4][4];

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            temp[j][3 - i] = blocks[b][i][j];
        }
    }

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            if (temp[i][j] != ' ') {

                int tx = x + j;
                int ty = y + i;

                if (tx < 1 || tx >= W - 1 || ty >= H - 1)
                    return false;

                if (board[ty][tx] != ' ')
                    return false;
            }
        }
    }

    return true;
}

void rotateBlock() {

    char temp[4][4];

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            temp[j][3 - i] = blocks[b][i][j];
        }
    }

    for (int i = 0; i < 4; i++) {

        for (int j = 0; j < 4; j++) {

            blocks[b][i][j] = temp[i][j];
        }
    }
}

int removeLines() {

    int linesCleared = 0;

    for (int i = H - 2; i >= 0; i--) {

        bool full = true;

        for (int j = 1; j < W - 1; j++) {

            if (board[i][j] == ' ') {

                full = false;
                break;
            }
        }

        if (full) {

            linesCleared++;

            for (int k = i; k > 0; k--) {

                for (int j = 1; j < W - 1; j++) {

                    board[k][j] = board[k - 1][j];
                }
            }

            for (int j = 1; j < W - 1; j++) {

                board[0][j] = ' ';
            }

            i++;
        }
    }

    return linesCleared;
}

void increaseSpeed(int linesCleared) {

    if (gameMode == 1) {
        speed -= linesCleared * 5;     // EASY tăng chậm
    }
    else {
        speed -= linesCleared * 20;    // HARD tăng mạnh
    }

    if (speed < MIN_SPEED)
        speed = MIN_SPEED;
}

bool gameOver() {

    for (int j = 1; j < W - 1; j++) {

        if (board[0][j] != ' ')
            return true;
    }

    return false;
}

int main() {

    srand((unsigned int)time(0));

    system("cls");
    cout << "====== TETRIS ======" << endl;
    cout << "1. EASY MODE" << endl;
    cout << "2. HARD MODE" << endl;
    cout << "Choose mode: ";
    cin >> gameMode;

    if (gameMode == 1) {
        speed = 300;   // rơi chậm
    }
    else {
        speed = 120;   // rơi nhanh
    }

    initBoard();

    b = rand() % 7;

    while (1) {

        boardDelBlock();

        if (_kbhit()) {

            char c = _getch();

            if (c == 'a') {

                if (canMove(-1, 0))
                    x--;
                    soundMove();
            }

            else if (c == 'd') {

                if (canMove(1, 0))
                    x++;
                    soundMove();
            }

            else if (c == 's') {

                if (canMove(0, 1))
                    y++;
                    soundDrop();
            }

            else if (c == 'w') {

                if (canRotate())
                    rotateBlock();
                    soundRotate();
            }

            else if (c == 'q') {

                break;
            }
        }

        if (canMove(0, 1)) {

            y++;
        }

        else {

            block2Board();

            int lines = removeLines();

            if (gameMode == 1)
                score += lines * 100;
            else
                score += lines * 200;   // HARD x2 điểm
            if (lines > 0) {
                soundClear();
            }

            increaseSpeed(lines);

            x = 5;
            y = 0;

            b = rand() % 7;

            if (gameOver()) {

                system("cls");

                cout << endl;
                cout << "========= GAME OVER =========" << endl;
                cout << "FINAL SCORE : " << score << endl;
                cout << "=============================" << endl;
                soundGameOver();
                break;
            }
        }

        block2Board();

        draw();

        Sleep(speed);
    }

    return 0;
}
