#include <iostream>
#include <conio.h>
#include <windows.h>
#include <ctime>
#include <cctype> 
#include <string> 

using namespace std;

#define H 20
#define W 15

// ==========================================
// LỚP TRỪU TƯỢNG PIECE (OOP - ĐA HÌNH)
// ==========================================
class Piece {
protected:
    char shape[4][4];
public:
    virtual void rotate() = 0;
    virtual char (*getShape())[4] = 0;
    virtual ~Piece() {}
};

// ==========================================
// LỚP KHỐI GẠCH CỤ THỂ (OOP - KẾ THỪA)
// ==========================================
class TetrisPiece : public Piece {
public:
    TetrisPiece(char init[4][4]) {
        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                shape[i][j] = init[i][j];
            }
        }
    }

    char (*getShape())[4] override {
        return shape;
    }

    // Xoay ma trận 90 độ
    void rotate() override {
        char temp[4][4];
        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                temp[j][3 - i] = shape[i][j];
            }
        }
        for (int i = 0; i < 4; i++) {
            for (int j = 0; j < 4; j++) {
                shape[i][j] = temp[i][j];
            }
        }
    }
};

// ==========================================
// DỮ LIỆU 7 KHỐI GẠCH KINH ĐIỂN
// ==========================================
char blocksData[][4][4] = {
    {{' ','I',' ',' '},{' ','I',' ',' '},{' ','I',' ',' '},{' ','I',' ',' '}},
    {{' ',' ',' ',' '},{' ','O','O',' '},{' ','O','O',' '},{' ',' ',' ',' '}},
    {{' ',' ',' ',' '},{' ','T',' ',' '},{'T','T','T',' '},{' ',' ',' ',' '}},
    {{' ',' ',' ',' '},{' ','S','S',' '},{'S','S',' ',' '},{' ',' ',' ',' '}},
    {{' ',' ',' ',' '},{'Z','Z',' ',' '},{' ','Z','Z',' '},{' ',' ',' ',' '}},
    {{' ',' ',' ',' '},{'J',' ',' ',' '},{'J','J','J',' '},{' ',' ',' ',' '}},
    {{' ',' ',' ',' '},{' ',' ','L',' '},{'L','L','L',' '},{' ',' ',' ',' '}}
};

// ==========================================
// BIẾN TOÀN CỤC
// ==========================================
char board[H][W];
Piece* currentPiece = nullptr;
int x = 5, y = 0;
int score = 0;
int speed = 200;
int gameMode = 1;
const int MIN_SPEED = 50;

// ==========================================
// XỬ LÝ ÂM THANH (DÙNG BEEP)
// ==========================================
void soundMove() { Beep(600, 40); }
void soundRotate() { Beep(800, 60); }
void soundDrop() { Beep(500, 30); }
void soundClear() { Beep(1200, 100); }
void soundGameOver() { Beep(400, 200); Beep(300, 200); Beep(200, 400); }

// ==========================================
// CÔNG CỤ HỖ TRỢ GIAO DIỆN
// ==========================================
void gotoxy(int x, int y) {
    COORD c = {(SHORT)x, (SHORT)y};
    SetConsoleCursorPosition(GetStdHandle(STD_OUTPUT_HANDLE), c);
}

void hideCursor() {
    HANDLE h = GetStdHandle(STD_OUTPUT_HANDLE);
    CONSOLE_CURSOR_INFO info = {100, FALSE};
    SetConsoleCursorInfo(h, &info);
}

void initBoard() {
    for (int i = 0; i < H; i++) {
        for (int j = 0; j < W; j++) {
            if (i == H - 1 || j == 0 || j == W - 1) board[i][j] = '#';
            else board[i][j] = ' ';
        }
    }
}

void spawnNewPiece() {
    int b = rand() % 7;
    if (currentPiece != nullptr) delete currentPiece;
    currentPiece = new TetrisPiece(blocksData[b]);
    x = 5; y = 0;
}

char (*shape())[4] { return currentPiece->getShape(); }

// ==========================================
// VẼ GAME (DÙNG STRING BUFFER CHỐNG CHỚP)
// ==========================================
void draw() {
    gotoxy(0, 0);
    string frame = "";
    for (int i = 0; i < H; i++) {
        for (int j = 0; j < W; j++) {
            if (board[i][j] == ' ') frame += "  ";
            else if (board[i][j] == '#') frame += "[]"; // Tường
            else frame += "[]"; // Khối gạch
        }
        frame += "\n";
    }
    frame += "\n========== TETRIS ==========\n";
    frame += "SCORE : " + to_string(score) + "\n";
    frame += "SPEED : " + to_string(speed) + " ms\n";
    frame += "MODE  : " + string(gameMode == 1 ? "EASY" : "HARD") + "\n";
    frame += "----------------------------\n";
    frame += "A,D,S : MOVE | W : ROTATE\n";
    frame += "SPACE : HARD DROP | P : PAUSE\n";
    cout << frame;
}

// ==========================================
// LOGIC XỬ LÝ VA CHẠM & TÍNH ĐIỂM
// ==========================================
void boardDelBlock() {
    auto s = shape();
    for (int i = 0; i < 4; i++)
        for (int j = 0; j < 4; j++)
            if (s[i][j] != ' ')
                if (y + i >= 0 && y + i < H && x + j >= 0 && x + j < W)
                    board[y + i][x + j] = ' ';
}

void block2Board() {
    auto s = shape();
    for (int i = 0; i < 4; i++)
        for (int j = 0; j < 4; j++)
            if (s[i][j] != ' ')
                board[y + i][x + j] = s[i][j];
}

bool canMove(int dx, int dy) {
    auto s = shape();
    for (int i = 0; i < 4; i++) {
        for (int j = 0; j < 4; j++) {
            if (s[i][j] != ' ') {
                int tx = x + j + dx;
                int ty = y + i + dy;
                if (tx < 1 || tx >= W - 1 || ty >= H - 1) return false;
                if (board[ty][tx] != ' ') return false;
            }
        }
    }
    return true;
}

bool canRotate() {
    TetrisPiece temp(*dynamic_cast<TetrisPiece*>(currentPiece));
    temp.rotate();
    auto s = temp.getShape();
    for (int i = 0; i < 4; i++) {
        for (int j = 0; j < 4; j++) {
            if (s[i][j] != ' ') {
                int tx = x + j, ty = y + i;
                if (tx < 1 || tx >= W - 1 || ty >= H - 1) return false;
                if (board[ty][tx] != ' ') return false;
            }
        }
    }
    return true;
}

int removeLines() {
    int linesCleared = 0;
    for (int i = H - 2; i >= 0; i--) {
        bool full = true;
        for (int j = 1; j < W - 1; j++) if (board[i][j] == ' ') { full = false; break; }
        if (full) {
            linesCleared++;
            for (int k = i; k > 0; k--)
                for (int j = 1; j < W - 1; j++) board[k][j] = board[k - 1][j];
            for (int j = 1; j < W - 1; j++) board[0][j] = ' ';
            soundClear();
            i++; 
        }
    }
    return linesCleared;
}

void increaseSpeed(int linesCleared) {
    if (linesCleared > 0) {
        speed -= linesCleared * (gameMode == 1 ? 5 : 15);
        if (speed < MIN_SPEED) speed = MIN_SPEED;
    }
}

// ==========================================
// VÒNG LẶP CHÍNH (MAIN LOOP)
// ==========================================
int main() {
    srand((unsigned int)time(0));
    hideCursor();

    system("cls");
    cout << "============================\n";
    cout << "     TETRIS PROJECT - UIT   \n";
    cout << "============================\n";
    cout << "1. EASY MODE\n2. HARD MODE\nChoose: ";
    cin >> gameMode;
    speed = (gameMode == 1) ? 300 : 120;
    system("cls");

    initBoard();
    spawnNewPiece();
    bool paused = false;

    while (true) {
        boardDelBlock();
        
        if (_kbhit()) {
            char c = tolower(_getch());
            if (c == 'p') paused = !paused;
            if (!paused) {
                if (c == 'a' && canMove(-1, 0)) { x--; soundMove(); }
                else if (c == 'd' && canMove(1, 0)) { x++; soundMove(); }
                else if (c == 's' && canMove(0, 1)) { y++; soundDrop(); }
                else if (c == 'w' && canRotate()) { currentPiece->rotate(); soundRotate(); }
                else if (c == ' ') { while (canMove(0, 1)) y++; soundDrop(); }
                else if (c == 'q') break;
            }
        }

        if (!paused) {
            if (canMove(0, 1)) {
                y++;
            } else {
                block2Board(); // Dán gạch vào bảng để chuẩn bị tính điểm
                int lines = removeLines();
                score += lines * (gameMode == 1 ? 100 : 200);
                increaseSpeed(lines);
                spawnNewPiece();
                
                if (!canMove(0, 0)) {
                    system("cls");
                    cout << "\n========= GAME OVER =========\n";
                    cout << "FINAL SCORE: " << score << "\n";
                    cout << "=============================\n";
                    soundGameOver();
                    break;
                }
            }
        }

        block2Board();
        draw();
        Sleep(speed);
    }

    delete currentPiece;
    return 0;
}
