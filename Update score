void updateScore(int linesCleared) {
    if (linesCleared <= 0) return;

    int basePoints = 0;

    switch (linesCleared) {
        case 1: basePoints = 100;  break; // Ăn 1 hàng
        case 2: basePoints = 300;  break; // Ăn 2 hàng (Thưởng thêm 100)
        case 3: basePoints = 500;  break; // Ăn 3 hàng (Thưởng thêm 200)
        case 4: basePoints = 800;  break; // Ăn 4 hàng 
    }

    // Nhân hệ số theo chế độ chơi
    if (gameMode == 2) { // HARD MODE
        score += basePoints * 2;
    } else {
        score += basePoints;
    }
}

